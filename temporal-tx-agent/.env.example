# ---------------------------------------------------------------------------
# For the eval demo (make record / make evals / make evals-cloud / make live)
# only these two matter:
# ---------------------------------------------------------------------------

# Required for `make record` and `make live` (real LLM reasoning).
# Without it, LLMClient falls back to a mock that always says "escalate",
# so contains_output(...) assertions can't match real reasoning.
OPENAI_API_KEY=

# Required only for `make evals-cloud` (LLM-graded evals via Okahu).
# Get a key at https://portal.okahu.co.
OKAHU_API_KEY=

# ---------------------------------------------------------------------------
# Optional — Monocle exporter destination. Defaults to local JSON files
# under .monocle/. Set to "file,okahu" to also ship traces to Okahu Cloud.
# ---------------------------------------------------------------------------
MONOCLE_EXPORTER=file

# ---------------------------------------------------------------------------
# Optional — override OpenAI models used by LLMClient / EmbeddingClient.
# Defaults below are OpenAI proper.
# ---------------------------------------------------------------------------
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Optional — point the OpenAI SDK at an OpenAI-compatible endpoint (any
# provider that speaks the OpenAI wire protocol). This env var is read
# directly by the openai Python SDK, so no code changes are needed.
#
# Examples:
#
# Nebius Token Factory (https://tokenfactory.nebius.com):
#   OPENAI_BASE_URL=https://api.tokenfactory.nebius.com/v1/
#   OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct
#   OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
#
# Nebius AI Studio:
#   OPENAI_BASE_URL=https://api.studio.nebius.ai/v1
#
# Any local OpenAI-compatible server (llama.cpp, vLLM, LM Studio, etc):
#   OPENAI_BASE_URL=http://localhost:8000/v1
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# NOT NEEDED for the eval demo. Only required if you want to run the
# original app's full stack (FastAPI + Temporal worker + Couchbase +
# Streamlit dashboard) via ./scripts/quick_setup.sh. The eval demo never
# touches Couchbase or a Temporal server — the recorder and live test
# call the AI clients and activity functions directly.
# ---------------------------------------------------------------------------
# COUCHBASE_CONNECTION_STRING=
# COUCHBASE_USERNAME=
# COUCHBASE_PASSWORD=
# COUCHBASE_BUCKET=transactions
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_NAMESPACE=default
# AUTO_APPROVAL_LIMIT=50000
# CONFIDENCE_THRESHOLD_APPROVE=85
